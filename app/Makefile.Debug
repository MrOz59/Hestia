####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/usr/local/bin/ || mkdir -p $(INSTALL_ROOT)/usr/local/bin/
	$(QINSTALL_PROGRAM) $(QMAKE_TARGET) $(INSTALL_ROOT)/usr/local/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/usr/local/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/local/bin/ 


install_desktop: first FORCE
	@test -d $(INSTALL_ROOT)/usr/local/share/applications/ || mkdir -p $(INSTALL_ROOT)/usr/local/share/applications/
	$(QINSTALL) /home/ozzy/Projects/Hestia/app/deploy/linux/com.moonlight_stream.Moonlight.desktop $(INSTALL_ROOT)/usr/local/share/applications/com.moonlight_stream.Moonlight.desktop

uninstall_desktop: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/local/share/applications/com.moonlight_stream.Moonlight.desktop
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/local/share/applications/ 


install_icons: first FORCE
	@test -d $(INSTALL_ROOT)/usr/local/share/icons/hicolor/scalable/apps/ || mkdir -p $(INSTALL_ROOT)/usr/local/share/icons/hicolor/scalable/apps/
	$(QINSTALL) /home/ozzy/Projects/Hestia/app/res/moonlight.svg $(INSTALL_ROOT)/usr/local/share/icons/hicolor/scalable/apps/moonlight.svg

uninstall_icons: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/local/share/icons/hicolor/scalable/apps/moonlight.svg
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/local/share/icons/hicolor/scalable/apps/ 


install_appstream: first FORCE
	@test -d $(INSTALL_ROOT)/usr/local/share/metainfo/ || mkdir -p $(INSTALL_ROOT)/usr/local/share/metainfo/
	$(QINSTALL) /home/ozzy/Projects/Hestia/app/deploy/linux/com.moonlight_stream.Moonlight.appdata.xml $(INSTALL_ROOT)/usr/local/share/metainfo/com.moonlight_stream.Moonlight.appdata.xml

uninstall_appstream: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/local/share/metainfo/com.moonlight_stream.Moonlight.appdata.xml
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/local/share/metainfo/ 


install: install_target install_desktop install_icons install_appstream  FORCE

uninstall: uninstall_target uninstall_desktop uninstall_icons uninstall_appstream  FORCE

