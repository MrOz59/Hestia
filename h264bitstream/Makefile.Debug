debug/h264_stream.o: h264bitstream/h264_stream.c h264bitstream/bs.h \
		h264bitstream/h264_stream.h \
		h264bitstream/h264_sei.h
	$(CC) -c $(CFLAGS) $(INCPATH) -o debug/h264_stream.o h264bitstream/h264_stream.c

